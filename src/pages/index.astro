---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Sen Yao</h1>
			<p>
				Data scientist and curious generalist. I work at the intersection of data science, statistics,
				computational biology, prodocts, and whatever problem happens to be in front of me.
			</p>
			<p>
				This is where I write about things I find interesting — methods worth knowing,
				observations from projects, and the occasional detour into something completely
				unrelated to work.
			</p>
			<p>
				<a href="/blog">Read the Blog &rarr;</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
